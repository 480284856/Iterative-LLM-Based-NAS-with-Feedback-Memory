\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Comparison of the iterative NAS pipeline on CIFAR-10 and ImageNette (one-epoch proxy accuracy) across three LLMs. Models generally show statistically significant improvement over single-shot generation ($p \approx 0$). DeepSeek on ImageNette is an outlier due to extremely low validation success rate.}}{6}{table.caption.14}\protected@file@percent }
\newlabel{table:summary}{{1}{6}{Comparison of the iterative NAS pipeline on CIFAR-10 and ImageNette (one-epoch proxy accuracy) across three LLMs. Models generally show statistically significant improvement over single-shot generation ($p \approx 0$). DeepSeek on ImageNette is an outlier due to extremely low validation success rate}{table.caption.14}{}}
\newlabel{table:summary@cref}{{[table][1][]1}{[1][5][]6}}
\newlabel{fig:ablation_deepseek_cifar}{{2a}{6}{First 100 iterations of DeepSeek-Coder 6.7B on CIFAR-10}{figure.caption.15}{}}
\newlabel{fig:ablation_deepseek_cifar@cref}{{[subfigure][1][2]2a}{[1][5][]6}}
\newlabel{sub@fig:ablation_deepseek_cifar}{{a}{6}{First 100 iterations of DeepSeek-Coder 6.7B on CIFAR-10}{figure.caption.15}{}}
\newlabel{sub@fig:ablation_deepseek_cifar@cref}{{[subfigure][1][2]2a}{[1][5][]6}}
\newlabel{fig:ablation_deepseek_imagenette}{{2b}{6}{First 100 iterations of DeepSeek-Coder 6.7B on ImageNette}{figure.caption.15}{}}
\newlabel{fig:ablation_deepseek_imagenette@cref}{{[subfigure][2][2]2b}{[1][5][]6}}
\newlabel{sub@fig:ablation_deepseek_imagenette}{{b}{6}{First 100 iterations of DeepSeek-Coder 6.7B on ImageNette}{figure.caption.15}{}}
\newlabel{sub@fig:ablation_deepseek_imagenette@cref}{{[subfigure][2][2]2b}{[1][5][]6}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Ablation study comparing the full pipeline (Base) against a baseline without the Prompt Improver (w/o Improver) over 100 iterations. Errors encountered before the first successful evaluation are plotted at 0\%, while subsequent errors fall back to the most recent valid accuracy. Without the Prompt Improver, DeepSeek-Coder suffers severe programmatic instability on CIFAR-10 (a) and completely fails to generate any valid networks on ImageNette (b) beyond its initial shots. The iterative evolutionary feedback is crucial for structural coherence.}}{6}{figure.caption.15}\protected@file@percent }
\newlabel{fig:ablation}{{2}{6}{Ablation study comparing the full pipeline (Base) against a baseline without the Prompt Improver (w/o Improver) over 100 iterations. Errors encountered before the first successful evaluation are plotted at 0\%, while subsequent errors fall back to the most recent valid accuracy. Without the Prompt Improver, DeepSeek-Coder suffers severe programmatic instability on CIFAR-10 (a) and completely fails to generate any valid networks on ImageNette (b) beyond its initial shots. The iterative evolutionary feedback is crucial for structural coherence}{figure.caption.15}{}}
\newlabel{fig:ablation@cref}{{[figure][2][]2}{[1][5][]6}}
